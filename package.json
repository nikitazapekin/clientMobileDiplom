{
  "name": "mytypescriptapp",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "start:no-check": "EXPO_NO_DEPENDENCY_VALIDATION=1 expo start",
    "start:offline": "EXPO_OFFLINE=1 expo start",
    "start:wifi": "expo start --lan",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "NODE_OPTIONS=\"--max-old-space-size=4096\" eslint --config eslint.config.js src/**/*.{js,jsx,ts,tsx}",
    "lint:fix": "NODE_OPTIONS=\"--max-old-space-size=4096\" eslint --config eslint.config.js src/**/*.{js,jsx,ts,tsx} --fix",
    "format": "prettier --write . && eslint --config eslint.config.js src/**/*.{js,jsx,ts,tsx} --fix",
    "postinstall": "node scripts/fix-metro-exports.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/stack": "^7.4.8",
    "axios": "^1.12.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-image-picker": "~17.0.11",
    "expo-status-bar": "~3.0.9",
    "jest-expo": "~54.0.17",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "socket.io-client": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.35.0",
    "@types/react": "~19.1.17",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
